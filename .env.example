# ── Serenity AI — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to git.

# Flask secret key — change this to a long random string in production
SECRET_KEY=your-secret-key-here

# Google Gemini API key — get it from https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key-here

# MongoDB URI (optional — app falls back to in-memory DB if not set)
# Format: mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>
MONGO_URI=
